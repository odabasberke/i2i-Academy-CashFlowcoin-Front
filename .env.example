# Copy this file to .env and fill in real values.
# .env is gitignored - never commit real secrets.

# ---------- PostgreSQL ----------
POSTGRES_DB=cryptopal
POSTGRES_USER=cryptopal_app
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

# ---------- Redis cache ----------
REDIS_PASSWORD=change_me_strong_password
REDIS_PORT=6379

# ---------- Spring Boot app (used once the app itself is containerized) ----------
SPRING_PROFILES_ACTIVE=local

# ---------- JWT ----------
# HS256 needs >= 32 bytes. Generate a real one with: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_characters_long_xx

# ---------- Google Gemini ----------
# Get a key at https://aistudio.google.com/apikey - never commit a real one.
GEMINI_API_KEY=change_me
# Optional - defaults to gemini-3.5-flash if unset.
GEMINI_MODEL=gemini-3.5-flash
